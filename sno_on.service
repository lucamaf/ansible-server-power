[Unit]
Description=Run sno_on ansible playbook daily in the morning
Wants=network-online.target
After=network-online.target

[Service]
Type=oneshot
Environment="ANSIBLE_CONFIG=/home/luca/Scripts/ansible_sno.cfg"
ExecStart=/usr/bin/ansible-playbook -i /home/luca/Scripts/inventory.ini /home/luca/Scripts/sno_on.yaml 
RemainAfterExit=false
StandardOutput=journal
StandardError=journal
